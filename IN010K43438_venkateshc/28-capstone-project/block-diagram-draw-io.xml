<mxfile host="app.diagrams.net">
  <diagram name="ABOC Architecture">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- USER -->
        <mxCell id="user" value="User Input&#10;(Natural Language)" style="rounded=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- PLANNER -->
        <mxCell id="planner" value="Planner Agent" style="rounded=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="300" y="50" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- PROCUREMENT -->
        <mxCell id="procurement" value="Procurement Agent" style="rounded=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- VENDOR -->
        <mxCell id="vendor" value="Vendor Agent&#10;(API Call)" style="rounded=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="700" y="50" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- FINANCE -->
        <mxCell id="finance" value="Finance Agent&#10;(Rules)" style="rounded=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="900" y="50" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- COMPLIANCE -->
        <mxCell id="compliance" value="Compliance Agent&#10;(RAG + Rules)" style="rounded=1;fillColor=#f5f5f5;" vertex="1" parent="1">
          <mxGeometry x="1100" y="50" width="170" height="60" as="geometry"/>
        </mxCell>

        <!-- VALIDATOR -->
        <mxCell id="validator" value="Validator Agent" style="rounded=1;fillColor=#d9ead3;" vertex="1" parent="1">
          <mxGeometry x="1300" y="50" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- APPROVAL -->
        <mxCell id="approval" value="Approval Agent" style="rounded=1;fillColor=#cfe2f3;" vertex="1" parent="1">
          <mxGeometry x="1500" y="50" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- NOTIFIER -->
        <mxCell id="notifier" value="Notifier Agent&#10;(Rich UI)" style="rounded=1;fillColor=#ead1dc;" vertex="1" parent="1">
          <mxGeometry x="1700" y="50" width="160" height="60" as="geometry"/>
        </mxCell>

        <!-- OUTPUT -->
        <mxCell id="output" value="Final Output&#10;(PO + Status + UI)" style="rounded=1;fillColor=#d0e0e3;" vertex="1" parent="1">
          <mxGeometry x="1900" y="50" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- EXTERNAL SYSTEM -->
        <mxCell id="vendor_api" value="Vendor Service API&#10;(FastAPI)" style="rounded=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="700" y="180" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- MEMORY -->
        <mxCell id="memory" value="Memory Layer&#10;(Short-term + Chroma DB)" style="rounded=1;fillColor=#e6f7ff;" vertex="1" parent="1">
          <mxGeometry x="1000" y="180" width="250" height="60" as="geometry"/>
        </mxCell>

        <!-- EDGES -->
        <mxCell edge="1" source="user" target="planner" parent="1"/>
        <mxCell edge="1" source="planner" target="procurement" parent="1"/>
        <mxCell edge="1" source="procurement" target="vendor" parent="1"/>
        <mxCell edge="1" source="vendor" target="finance" parent="1"/>
        <mxCell edge="1" source="finance" target="compliance" parent="1"/>
        <mxCell edge="1" source="compliance" target="validator" parent="1"/>
        <mxCell edge="1" source="validator" target="approval" parent="1"/>
        <mxCell edge="1" source="approval" target="notifier" parent="1"/>
        <mxCell edge="1" source="notifier" target="output" parent="1"/>

        <!-- External connections -->
        <mxCell edge="1" source="vendor" target="vendor_api" parent="1" style="dashed=1"/>
        <mxCell edge="1" source="compliance" target="memory" parent="1" style="dashed=1"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>